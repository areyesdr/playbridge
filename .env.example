# PostgreSQL — connection string de Supabase (Settings → Database)
# Si se deja vacío, usa SQLite local (sync.db) — ideal para PC/Termux
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Flask — genera uno con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-seguro

# Spotify (developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://playbridge.onrender.com/callback

# Opcional
DEMO=0
PORT=5000
